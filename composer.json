{
    "name": "nikservik/commons",
    "description": "Useful code package for Laravel",
    "type": "package",
    "license": "MIT",
    "authors": [
        {
            "name": "Sergey Nikiforov",
            "email": "ser.nikiforov@gmail.com"
        }
    ],
    "require": {
        "php": "^7.4|^8.0",
        "ext-json": "*",
        "illuminate/config": "^8.0|^9.0|^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.3|^9.5",
        "nesbot/carbon": "^2.42.0",
        "orchestra/testbench": "^6.16|^7.0",
        "fakerphp/faker": "^1.14"
    },
    "autoload": {
        "psr-4": {
            "Nikservik\\Commons\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nikservik\\Commons\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "aliases": {
                "Has": "Nikservik\\Commons\\Has"
            },
            "providers": [
                "Nikservik\\Commons\\CommonsServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "psalm": "vendor/bin/psalm",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
        "format": "vendor/bin/php-cs-fixer fix --allow-risky=yes"
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "audit": {
            "ignore": [
                "PKSA-8qx3-n5y5-vvnd",
                "PKSA-w7xr-vk7n-rstm"
            ]
        }
    }
}
